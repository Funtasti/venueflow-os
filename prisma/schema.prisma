generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Zone {
  id               String   @id @default(cuid())
  name             String
  capacity         Int
  currentOccupancy Int      @default(0)
  status           String   @default("Low") // "Low", "Moderate", "Crowded"
  queues           Queue[]
  incidents        Incident[]
  incentives       Incentive[]
}

model Queue {
  id                String   @id @default(cuid())
  zoneId            String
  zone              Zone     @relation(fields: [zoneId], references: [id])
  type              String   // "Food", "Merch", "Restroom"
  estimatedWaitTime Int      @default(0)
  activeTickets     Int      @default(0)
}

model Incident {
  id            String   @id @default(cuid())
  location      String   // Map to Zone Id
  zone          Zone     @relation(fields: [location], references: [id])
  type          String
  assignedStaff String   @default("Unassigned")
  status        String   @default("Active") // "Active", "Resolved"
  urgency       String
  timestamp     DateTime @default(now())
}

model Incentive {
  id           String   @id @default(cuid())
  targetZoneId String
  zone         Zone     @relation(fields: [targetZoneId], references: [id])
  description  String
  active       Boolean  @default(true)
}
