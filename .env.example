# VenueFlow OS — Environment Variables
# Copy this file to .env and fill in your values.

# PostgreSQL connection string (Prisma).
# If left empty, the app falls back to the local JSON file in data/db.json.
# DATABASE_URL="postgresql://user:password@host:5432/venueflow?sslmode=require"

# Port the server listens on (Cloud Run injects this automatically).
PORT=8080